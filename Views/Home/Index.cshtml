@{
    ViewData["Title"] = "Home Page";
}
<head>
 <link rel="stylesheet" href="wwwroot\css\site.css">

</head>
<div class="text-center">
    <h1 class="display-4">La Romineta</h1>
    <img src="~/img/romivaga.png" alt = "Logo"/>
    <ul>
    @foreach(Integrante integrante in ViewBag.grupo.DevolverIntegrantes().Values) {

        
        <li> <a href='@Url.Action("SelectIntegrante", "Home", new { dni = integrante.getDNI()})'>@integrante.getNombre()</a> </li>
        
    }
    </ul>
</div>
